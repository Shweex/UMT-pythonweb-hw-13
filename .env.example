# API
WEB_PORT=8000

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=contacts_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USER_CACHE_TTL_SECONDS=3600

# JWT
AUTH_JWT_SECRET=your_auth_jwt_secret_here
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ACCESS_EXPIRATION_SECONDS=3600

# Email verification and password reset
MAIL_JWT_SECRET=your_mail_jwt_secret_here
MAIL_JWT_EXPIRATION_SECONDS=172800
PASSWORD_RESET_JWT_EXPIRATION_SECONDS=3600
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_app_password
MAIL_FROM=your_email@gmail.com
MAIL_FROM_NAME=Contacts API
MAIL_STARTTLS=false
MAIL_SSL_TLS=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cloudinary
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Default avatar for regular users
DEFAULT_AVATAR_URL=https://res.cloudinary.com/demo/image/upload/avatar_default.png
